# =============================================================================
# XVault Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic (Agent Reasoning)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# OKX API (DEX + DeFi + Security)
# -----------------------------------------------------------------------------
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=
OKX_BASE_URL=https://www.okx.com

# OKX X Layer RPC
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_CHAIN_ID=196

# -----------------------------------------------------------------------------
# OKX MCP Server
# -----------------------------------------------------------------------------
MCP_SERVER_URL=http://localhost:3001
MCP_API_KEY=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# x402 Protocol (Agent Economy)
# -----------------------------------------------------------------------------
X402_FACILITATOR_URL=https://facilitator.cdp.coinbase.com
X402_NETWORK=base-sepolia

# -----------------------------------------------------------------------------
# Agent Agentic Wallets (Private Keys — NEVER commit real values)
# -----------------------------------------------------------------------------
SIGNAL_AGENT_PRIVATE_KEY=0x...
RISK_AGENT_PRIVATE_KEY=0x...
EXECUTION_AGENT_PRIVATE_KEY=0x...
PORTFOLIO_AGENT_PRIVATE_KEY=0x...
ECONOMY_AGENT_PRIVATE_KEY=0x...

# Treasury master wallet
TREASURY_WALLET_ADDRESS=0x...
TREASURY_WALLET_PRIVATE_KEY=0x...

# Agent wallet addresses (derived from private keys; set separately for convenience)
SIGNAL_AGENT_WALLET_ADDRESS=0x...
RISK_AGENT_WALLET_ADDRESS=0x...
EXECUTION_AGENT_WALLET_ADDRESS=0x...
PORTFOLIO_AGENT_WALLET_ADDRESS=0x...
# Economy Agent master wallet — registered on OKX X Layer via `onchainos wallet login`
ECONOMY_AGENT_WALLET_ADDRESS=0xb5c600f74627c63476f7a7e89a6a616723783fce

# x402 service provider address (receives agent purchase payments)
SERVICE_PROVIDER_ADDRESS=0x...

# -----------------------------------------------------------------------------
# App Config
# -----------------------------------------------------------------------------
APP_ENV=development
APP_SECRET_KEY=super-secret-change-in-production
CORS_ORIGINS=http://localhost:3000

# Agent loop intervals (seconds)
SIGNAL_AGENT_INTERVAL=300
PORTFOLIO_AGENT_INTERVAL=300
ECONOMY_AGENT_INTERVAL=900

# Risk thresholds
MAX_TRADE_SIZE_USD=10000
MIN_SECURITY_SCORE=80
MAX_PORTFOLIO_CONCENTRATION=0.25

# Performance fee
PERFORMANCE_FEE_BPS=1000   # 10%

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# Redis (optional, for pub/sub)
REDIS_URL=redis://localhost:6379
